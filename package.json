{
  "name": "phaser-project-template",
  "version": "1.0.5",
  "description": "Phaser 3 starter template with TypeScript and webpack.",
  "homepage": "https://github.com/JernejHabjan/fuzzy-waddle#readme.md",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --config webpack/webpack.dev.js",
    "build": "rimraf dist && webpack --config webpack/webpack.prod.js",
    "serve-dist": "serve dist",
    "lint": "npm-run-all --parallel lint:*",
    "lint:css": "stylelint ./**/*.{css,scss,sass,html} --ignore-path .gitignore",
    "lint:ts": "eslint . --ignore-path .gitignore",
    "lint-fix": "npm-run-all --parallel lint-fix:*",
    "lint-fix:css": "stylelint --fix \"*.{html,css}\"",
    "lint-fix:ts": "eslint --quiet --fix --ignore-path .gitignore",
    "test": "jest",
    "prepare": "husky install",
    "semantic-release": "semantic-release"
  },
  "lint-staged": {
    "*.{js,ts,html}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{html,css}": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "Phaser",
    "Phaser 3",
    "Phaser3",
    "html5 game",
    "TypeScript",
    "webpack",
    "starter"
  ],
  "author": {
    "name": "Jernej Habjan",
    "url": "https://github.com/JernejHabjan"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JernejHabjan/fuzzy-waddle.git"
  },
  "engines": {
    "node": ">=12"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/git",
      [
        "@semantic-release/github",
        {
          "assets": "dist/*",
          "label": "Game Files"
        }
      ]
    ]
  },
  "license": "MIT",
  "devDependencies": {
    "@semantic-release/git": "^10.0.0",
    "@types/jest": "^27.0.2",
    "@typescript-eslint/eslint-plugin": "^5.1.0",
    "@typescript-eslint/parser": "^5.1.0",
    "copy-webpack-plugin": "^9.0.1",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-html": "^6.2.0",
    "eslint-plugin-prettier": "^4.0.0",
    "html-webpack-plugin": "^5.4.0",
    "husky": "^7.0.2",
    "javascript-obfuscator": "^3.0.0",
    "jest": "^27.3.0",
    "lint-staged": "^11.2.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.4.1",
    "prettier-stylelint": "^0.4.2",
    "rimraf": "^3.0.2",
    "semantic-release": "^18.0.0",
    "serve": "^12.0.1",
    "stylelint": "^13.13.1",
    "stylelint-config-standard": "^22.0.0",
    "ts-jest": "^27.0.7",
    "ts-loader": "^9.2.6",
    "ts-node": "^10.3.0",
    "typescript": "^4.4.4",
    "webpack": "^5.58.2",
    "webpack-cli": "^4.9.1",
    "webpack-dev-server": "^4.3.1",
    "webpack-merge": "^5.8.0",
    "webpack-obfuscator": "^3.5.0",
    "workbox-webpack-plugin": "^6.3.0"
  },
  "dependencies": {
    "phaser": "^3.55.2"
  }
}
