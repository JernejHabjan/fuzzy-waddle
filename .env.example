# Copy this file to .env in the project root and fill in values for local development.

# Nx workspace compatibility
NX_ADD_PLUGINS=false

# API runtime configuration
# Allowed browser origins for the Nest API and WebSocket gateways.
CORS_ORIGIN=http://localhost:4200
# Supabase database password. For self-hosted Supabase, copy `POSTGRES_PASSWORD` from the Supabase Docker `.env` file.
SUPABASE_DB_PASSWORD=your-super-secret-and-long-postgres-password
# Supabase project or local API URL.
SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase service-role API key. For self-hosted Supabase, copy `SERVICE_ROLE_KEY` from the Supabase Docker `.env` file.
SUPABASE_SERVICE_KEY=your-service-role-key
