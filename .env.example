#### SUPABASE CLI LOCAL AUTH ####
# The local Supabase CLI also reads this root `.env` because `supabase/config.toml`
# references these values with env(...).

# Google OAuth client ID for the local Supabase Auth Google provider.
# Obtain it in Google Cloud Console:
# 1. APIs & Services > Credentials
# 2. Create Credentials > OAuth client ID
# 3. Application type: Web application
# 4. Authorized redirect URI: http://127.0.0.1:54321/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=

# Google OAuth client secret from the same Google Cloud OAuth client.
# Keep this value local and never commit a filled-in secret.
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
