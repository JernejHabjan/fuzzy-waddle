{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ashes of the Ancients",
  "version": "1.0.0",
  "identifier": "com.fuzzywaddle.probablewaffle",
  "build": {
    "frontendDist": "../../../dist/apps/client",
    "devUrl": "http://localhost:4200/aota"
  },
  "app": {
    "windows": [
      {
        "title": "Ashes of the Ancients",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
