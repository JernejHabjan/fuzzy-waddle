#### GENERAL ####
# Copy this file to `apps/api/.env.local` for local API development.
#
# Comma-separated browser origins allowed to call the Nest API and Socket.IO gateways.
# Local Angular dev server:
CORS_ORIGIN=http://localhost:4200

#### SUPABASE AWS ####
# Hosted Supabase project URL.
# Obtain from Supabase Dashboard > Project Settings > Data API/API > Project URL.
SUPABASE_URL=https://bhzetyxjimpabioxoodz.supabase.co

# Server-only Supabase service role key for the Nest API.
# Obtain from Supabase Dashboard > Project Settings > API keys > service_role.
# Never expose this in Angular/client code.
SUPABASE_SERVICE_KEY=eyJ...

#### SUPABASE LOCAL ####
# To run the API against `supabase start`, copy these values into SUPABASE_URL and
# SUPABASE_SERVICE_KEY above, or export them in your shell before starting the API.
__SUPABASE_URL=http://127.0.0.1:54321

# Local secret key from `supabase status`.
# Copy the `Authentication Keys > Secret` value.
__SUPABASE_SERVICE_KEY=sb_secret_...
